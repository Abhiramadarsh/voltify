{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique identifier" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to profile photo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles identified by Auth UID"
    }
  }
}
